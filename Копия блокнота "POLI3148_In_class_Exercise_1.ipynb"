00\n","  impact_is_tax_cut = is_tax_cut * 2000\n","  impact_total = impact_gdp_growth + impact_unemployment_rate + impact_is_tax_cut + impact_base\n","\n","  if stability_level == 3:\n","        impact_total *= 1.15\n","  elif stability_level == 2:\n","        impact_total *= 1.10\n","\n","  print(f\"The adjusted economic impact is {impact_total}.\")\n","  return\n"],"metadata":{"id":"57rnMWFn-T-H","executionInfo":{"status":"ok","timestamp":1770517695407,"user_tz":-480,"elapsed":4,"user":{"displayName":"Victoria Kobzeva","userId":"00262820123580309343"}}},"execution_count":265,"outputs":[]},{"cell_type":"code","source":["calculate_impact(2, 5, False, 2)\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"sMvdbyyC9nil","executionInfo":{"status":"ok","timestamp":1770517696410,"user_tz":-480,"elapsed":11,"user":{"displayName":"Victoria Kobzeva","userId":"00262820123580309343"}},"outputId":"c0cc0984-1974-4512-c66f-e6339a7d7486"},"execution_count":266,"outputs":[{"output_type":"stream","name":"stdout","text":["The adjusted economic impact is 550.0.\n"]}]},{"cell_type":"code","source":["calculate_impact(3, 4, True, 3)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"59okLxm--9Pg","executionInfo":{"status":"ok","timestamp":1770517697718,"user_tz":-480,"elapsed":4,"user":{"displayName":"Victoria Kobzeva","userId":"00262820123580309343"}},"outputId":"4857d531-cb73-454d-be97-c09e82da84ae"},"execution_count":267,"outputs":[{"output_type":"stream","name":"stdout","text":["The adjusted economic impact is 3794.9999999999995.\n"]}]},{"cell_type":"code","source":["def calculate_impact(stability_level, gdp_growth, is_tax_cut, political_stability):\n","    impact_base = 1000\n","    impact_gdp_growth = gdp_growth * 500\n","    impact_is_tax_cut = is_tax_cut * 2000\n","\n","    # Сначала применяем уровень стабильности (stability_level)\n","    impact_total = impact_gdp_growth + impact_is_tax_cut + impact_base\n","    impact_total = impact_total * (1 